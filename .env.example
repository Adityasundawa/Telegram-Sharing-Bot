# ============================
# Telegram Bot Configuration
# ============================
# Copy file ini menjadi .env lalu isi nilainya
# cp .env.example .env

# Bot token dari @BotFather
TG_BOT_TOKEN=

# API ID dari my.telegram.org
APP_ID=

# API Hash dari my.telegram.org
API_HASH=

# Channel ID untuk menyimpan file (contoh: -1001234567890)
CHANNEL_ID=

# Telegram ID pemilik bot
OWNER_ID=

# Port untuk web server (default: 8080)
PORT=8080

# MongoDB connection URL
DATABASE_URL=mongodb://localhost:27017

# Nama database MongoDB
DATABASE_NAME=filesharingbot

# Force Subscribe Channel IDs (pisahkan dengan koma)
# Contoh: -1003791124160,-1003734633464
FORCE_SUB_CHANNEL=

# Jumlah bot workers (default: 4)
TG_BOT_WORKERS=4

# Pesan start bot (support HTML dan fillings: {first}, {last}, {id}, {mention}, {username})
START_MESSAGE=Hello {first}\n\nI can store private files in Specified Channel and other users can access it from special link.

# Admin user IDs (pisahkan dengan spasi)
# Contoh: 123456789 987654321
ADMINS=

# Pesan Force Subscribe (support HTML dan fillings)
FORCE_SUB_MESSAGE=Hello {first}\n\n<b>Wajib Join channel dibawah ini!</b>

# Custom caption untuk dokumen (kosongkan untuk disable)
# Fillings: {filename}, {previouscaption}
CUSTOM_CAPTION=

# Set True untuk mencegah file di-forward
PROTECT_CONTENT=True

# Set True untuk disable tombol Share di channel
DISABLE_CHANNEL_BUTTON=False

# Teks custom untuk command /stats (filling: {uptime})
BOT_STATS_TEXT=<b>BOT UPTIME</b>\n{uptime}

# Teks balasan saat user kirim pesan langsung
USER_REPLY_TEXT=❌Don't send me messages directly I'm only File Share bot!